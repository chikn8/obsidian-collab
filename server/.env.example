# ── Obsidian Collab server — environment template ──────────────────────────────
# Copy to .env for local dev, or set these in Railway for production.

# Listen address
PORT=8080
HOST=0.0.0.0

# ── Auth (REQUIRED in production) ──────────────────────────────────────────────
# Mints + validates per-share capability tokens. Generate: openssl rand -hex 24
SERVER_SECRET=
# Global password for the legacy (un-namespaced) share. Generate: openssl rand -hex 16
# Not needed if DISABLE_LEGACY_ROOMS=true.
AUTH_TOKEN=
# Separate secret for /admin/revoke (defaults to SERVER_SECRET). Recommended distinct.
ADMIN_SECRET=
# Bearer token for /metrics (defaults to ADMIN_SECRET). Metrics include room/file metadata.
METRICS_TOKEN=
# Bearer token allowed to create new shares (defaults to ADMIN_SECRET). This is
# narrower than SERVER_SECRET: it cannot derive keys for existing shares offline.
SHARE_MINT_TOKEN=
# Secret used to validate per-share owner keys (defaults to ADMIN_SECRET).
SHARE_OWNER_SECRET=
# Append-only JSONL audit trail. Defaults to $PERSIST_DIR/audit.jsonl.
AUDIT_LOG_PATH=
# Refuse to start without strong secrets. Auto-true when NODE_ENV=production.
REQUIRE_AUTH=true
MIN_SECRET_LENGTH=16
# Reject all legacy/un-namespaced rooms (then AUTH_TOKEN is unnecessary).
DISABLE_LEGACY_ROOMS=false

# ── Persistence (mount a PERSISTENT VOLUME at PERSIST_DIR in prod) ──────────────
PERSIST_DIR=/data/collab-data
# /health returns 503 if the newest save is older than this while rooms are active (ms).
STALE_SAVE_MS=120000
# /health returns 503 below this much free disk (bytes).
MIN_FREE_BYTES=104857600

# ── Abuse caps ─────────────────────────────────────────────────────────────────
# Max inbound WebSocket frame in bytes (anti-bloat / OOM).
WS_MAX_PAYLOAD=2097152

# ── Off-box backup (STRONGLY recommended — the volume is otherwise single-point) ─
# Private git remote that receives the note-history snapshots repo.
SNAPSHOT_GIT_REMOTE=
SNAPSHOT_GIT_BRANCH=main
# When true, /health returns 503 until snapshot git push is configured and healthy.
REQUIRE_SNAPSHOT_REMOTE=false
# Periodic full-corpus backup command. $PERSIST_DIR is exported to the command.
# Example: tar -C "$PERSIST_DIR" -czf /tmp/bk.tgz . && rclone copy /tmp/bk.tgz r2:bucket/$(date -u +%FT%TZ).tgz
PERSIST_BACKUP_COMMAND=
# When true, /health returns 503 until PERSIST_BACKUP_COMMAND is configured and healthy.
REQUIRE_PERSIST_BACKUP=false
PERSIST_BACKUP_INTERVAL_MS=86400000
PERSIST_BACKUP_JITTER_MS=300000
PERSIST_BACKUP_TIMEOUT_MS=1800000

# ── Alerting / notifications ───────────────────────────────────────────────────
# ntfy topic that receives ops alerts (save/backup/corruption failures), deduped.
OPS_NTFY_TOPIC=
# ntfy server for @mention pushes + ops alerts.
NTFY_SERVER=https://ntfy.sh
