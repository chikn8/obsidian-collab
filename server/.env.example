# ── Obsidian Collab server — environment template ──────────────────────────────
# Copy to .env for local dev, or set these in Railway for production.

# Listen address
PORT=8080
HOST=0.0.0.0

# ── Auth (REQUIRED in production) ──────────────────────────────────────────────
# Mints + validates per-share capability tokens. Generate: openssl rand -hex 24
SERVER_SECRET=
# Comma-separated old server secrets accepted only for verification during a
# temporary rotation window. New links are always minted with SERVER_SECRET.
SERVER_SECRET_PREVIOUS=
# Global password for the legacy (un-namespaced) share. Generate: openssl rand -hex 16
# Not needed if DISABLE_LEGACY_ROOMS=true.
AUTH_TOKEN=
AUTH_TOKEN_PREVIOUS=
# Separate secret for /admin/revoke (defaults to SERVER_SECRET). Recommended distinct.
ADMIN_SECRET=
ADMIN_SECRET_PREVIOUS=
# Bearer token for /metrics (defaults to ADMIN_SECRET). Metrics include room/file metadata.
METRICS_TOKEN=
# Bearer token allowed to create new shares (defaults to ADMIN_SECRET). This is
# narrower than SERVER_SECRET: it cannot derive keys for existing shares offline.
SHARE_MINT_TOKEN=
SHARE_MINT_TOKEN_PREVIOUS=
# Secret used to validate per-share owner keys (defaults to ADMIN_SECRET).
SHARE_OWNER_SECRET=
SHARE_OWNER_SECRET_PREVIOUS=
# Append-only JSONL audit trail. Defaults to $PERSIST_DIR/audit.jsonl.
AUDIT_LOG_PATH=
# Refuse to start without strong secrets. Auto-true when NODE_ENV=production.
REQUIRE_AUTH=true
MIN_SECRET_LENGTH=16
# Reject all legacy/un-namespaced rooms (then AUTH_TOKEN is unnecessary).
DISABLE_LEGACY_ROOMS=false

# ── Persistence (mount a PERSISTENT VOLUME at PERSIST_DIR in prod) ──────────────
PERSIST_DIR=/data/collab-data
# /health returns 503 if the newest save is older than this while rooms are active (ms).
STALE_SAVE_MS=120000
# /health returns 503 below this much free disk (bytes).
MIN_FREE_BYTES=104857600

# ── Runtime memory guardrails ─────────────────────────────────────────────────
# Docker defaults NODE_OPTIONS to --max-old-space-size=384; override here if your
# Railway memory limit is higher/lower.
NODE_OPTIONS=--max-old-space-size=384
# /health returns 503 when RSS/heap pass these limits. RSS defaults to 92% of a
# detected cgroup/container memory limit if unset. Set 0 to disable.
MEMORY_HEALTH_MAX_RSS_BYTES=0
MEMORY_HEALTH_MAX_HEAP_USED_BYTES=0
MEMORY_HEALTH_CGROUP_RATIO=0.92

# ── Abuse caps ─────────────────────────────────────────────────────────────────
# Max inbound WebSocket frame in bytes (anti-bloat / OOM).
WS_MAX_PAYLOAD=2097152
# Verbose redacted relay diagnostics. Keep false normally; turn on briefly when
# investigating feedback loops, dropped writes, or awareness/presence glitches.
SYNC_DEBUG_LOG=false
SYNC_LOG_LARGE_UPDATE_BYTES=65536
SYNC_LOG_LARGE_TEXT_DELTA=20480
# Retain redacted structured server logs to disk. Enabled automatically in
# NODE_ENV=production unless SERVER_LOG_DRAIN=false. Defaults to
# $PERSIST_DIR/server.jsonl, rotated at SERVER_LOG_MAX_BYTES.
SERVER_LOG_DRAIN=
SERVER_LOG_PATH=
SERVER_LOG_MAX_BYTES=10485760
SERVER_LOG_ROTATE_COUNT=3
# Max content-addressed attachment/blob upload size in bytes.
BLOB_MAX_BYTES=26214400
# Attachment blob backend. `fs` stores under $PERSIST_DIR/blobs; `s3` uses the
# S3-compatible vars below (Cloudflare R2, Backblaze B2 S3, AWS S3, etc.).
BLOB_STORE=fs
BLOB_S3_ENDPOINT=
BLOB_S3_BUCKET=
BLOB_S3_REGION=auto
BLOB_S3_ACCESS_KEY_ID=
BLOB_S3_SECRET_ACCESS_KEY=
BLOB_S3_SESSION_TOKEN=
BLOB_S3_PREFIX=obsidian-collab/blobs

# ── Off-box backup (STRONGLY recommended — the volume is otherwise single-point) ─
# Private git remote that receives the note-history snapshots repo.
# Use an SSH deploy key with write access, e.g. git@github.com:owner/obsidian-collab-snapshots.git.
SNAPSHOT_GIT_REMOTE=
SNAPSHOT_GIT_BRANCH=main
# Private key for SNAPSHOT_GIT_REMOTE/PERSIST_BACKUP_GIT_REMOTE. Railway may store it as either
# a real multiline secret or with escaped \n newlines.
SNAPSHOT_GIT_SSH_KEY=
# Defaults to true when NODE_ENV=production, false otherwise. Set false only for intentional no-backup dev.
REQUIRE_SNAPSHOT_REMOTE=
# Periodic full-corpus backup command. $PERSIST_DIR is exported to the command.
# Example: tar -C "$PERSIST_DIR" -czf /tmp/bk.tgz . && rclone copy /tmp/bk.tgz r2:bucket/$(date -u +%FT%TZ).tgz
# Git-only example using the bundled script: sh scripts/git-full-backup.sh
PERSIST_BACKUP_COMMAND=
# Optional; defaults to SNAPSHOT_GIT_REMOTE when the bundled git backup script is used.
PERSIST_BACKUP_GIT_REMOTE=
PERSIST_BACKUP_GIT_BRANCH=backups
# Defaults to true when NODE_ENV=production, false otherwise. Set false only for intentional no-backup dev.
REQUIRE_PERSIST_BACKUP=
PERSIST_BACKUP_INTERVAL_MS=86400000
PERSIST_BACKUP_JITTER_MS=300000
PERSIST_BACKUP_TIMEOUT_MS=1800000
# Startup grace before /health requires the first successful backup. Defaults to 30m in production.
PERSIST_BACKUP_STARTUP_GRACE_MS=

# ── Alerting / notifications ───────────────────────────────────────────────────
# ntfy topic that receives ops alerts (save/backup/corruption failures), deduped.
OPS_NTFY_TOPIC=
# Defaults to true in production, false outside production.
REQUIRE_OPS_ALERTS=
# Internal /health checker cadence. Defaults to 60000 in production, 0 outside
# production. Set 0 to disable if your host already alerts on /health.
HEALTH_ALERT_INTERVAL_MS=
# ntfy server for @mention pushes + ops alerts.
NTFY_SERVER=https://ntfy.sh
